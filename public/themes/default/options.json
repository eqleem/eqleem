{
    "primaryColor": {
        "type": "picker-color",
        "label": "لون القالب",
        "allowCustom": true,
        "options": [
            "blue",
            "cyan",
            "green",
            "teal",
            "sky",
            "purple",
            "violet",
            "indigo",
            "red",
            "pink",
            "fuchsia",
            "orange",
            "amber",
            "yellow",
            "zinc",
            "emerald",
            "lime",
            "rose",
            "gray"
        ],
        "default": "blue"
    },
    "headerImage": {
        "type": "upload-cover",
        "label": "صورة الغلاف",
        "info": "اختر لوناً أو تدرجاً أو ارفع صورة أو اختر من Unsplash.",
        "positionKey": "headerImagePosition",
        "default": ""
    },
    "bgColor": {
        "type": "tailwindcss-colorpicker-light",
        "label": "Background color",
        "default": "gray-300"
    },

    "headerImagePosition": {
        "type": "cover-position",
        "default": 50
    },
    "logoRadius": {
        "type": "radio",
        "label": "شكل انحناء الشعار",
        "info": "قم باختيار طريقة عرض  حواف الشعار.",
        "options": [
            "rounded-full",
            "rounded-2xl",
            "rounded-lg",
            "rounded-md",
            "rounded-none"
        ],
        "default": "full"
    },
    "fontFamily": {
        "type": "radio",
        "label": "نوع الخط",
        "info": "اختر الخط الأساسي لصفحتك.",
        "options": {
            "sarmady": "سرمدي",
            "ibmps": "IBM Plex",
            "milligram": "ميليجرام",
            "eqleem": "إقليد"
        },
        "default": "sarmady"
    }
}
